# Copy to .env and adjust. Every variable the stack knows about is listed here;
# nothing secret is committed. Docker Compose reads this file for interpolation,
# and the API loads it for non-Docker local runs.

# --- Postgres (compose provisions the container with these) ---
POSTGRES_USER=aero
POSTGRES_PASSWORD=aero_dev_password
POSTGRES_DB=aero

# --- API ---
NODE_ENV=development
PORT=3000
# Reserved for the separate-origin PDF proxy (phase 03).
FILE_ORIGIN_PORT=3001
# Used for non-Docker local runs; inside Docker Compose the API is pointed at
# the postgres service automatically.
DATABASE_URL=postgresql://aero:aero_dev_password@localhost:5432/aero
LOG_LEVEL=info

# --- MinIO (local stand-in for Cloudflare R2) ---
MINIO_ROOT_USER=aero
MINIO_ROOT_PASSWORD=aero_dev_password
S3_BUCKET=aero-documents

# --- Web ---
# Where the Vite dev server proxies /api requests for non-Docker local runs;
# inside Docker Compose this is set to http://api:3000 automatically.
API_PROXY_TARGET=http://localhost:3000
