# Copy to .env and adjust. Every variable the stack knows about is listed here;
# nothing secret is committed. Docker Compose reads this file for interpolation,
# and the API loads it for non-Docker local runs.

# --- Postgres (compose provisions the container with these) ---
POSTGRES_USER=aero
POSTGRES_PASSWORD=aero_dev_password
POSTGRES_DB=aero

# --- API ---
NODE_ENV=development
PORT=3000
# The separate-origin PDF proxy: PDFs are served from their own port (own
# hostname in production) so hostile uploads can never script against the app.
FILE_ORIGIN_PORT=3001
# What the browser uses to reach the file origin; document URLs in API
# responses are built from it. Must differ from the app origin.
FILE_ORIGIN_BASE_URL=http://localhost:3001
# Used for non-Docker local runs; inside Docker Compose the API is pointed at
# the postgres service automatically.
DATABASE_URL=postgresql://aero:aero_dev_password@localhost:5432/aero
LOG_LEVEL=info

# --- Auth (ROBLOX OAuth 2.0) ---
# Public origin the browser reaches the app at; every OAuth URL derives from it.
# Locally this is the Vite dev server, which proxies /auth and /api to the API.
APP_BASE_URL=http://localhost:5173
# From the ROBLOX Creator Hub OAuth app (see README — ROBLOX app registration).
# Optional in development (login is disabled until set), required in production.
ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=
# Signs session/OAuth-state cookies. Fine as-is locally; generate a fresh value
# for any deployed environment: openssl rand -hex 32
SESSION_SECRET=aero_dev_session_secret_do_not_use_in_prod
# Secure flag on auth cookies. Defaults off in development (Safari drops Secure
# cookies on plain-http origins, including localhost) and on in production,
# where disabling it refuses boot. Uncomment only for TLS-enabled local setups.
# COOKIE_SECURE=true

# --- MinIO (local stand-in for Cloudflare R2) ---
MINIO_ROOT_USER=aero
MINIO_ROOT_PASSWORD=aero_dev_password
S3_BUCKET=aero-documents

# --- Object storage (the API's S3 client) ---
# Unset values fall back to the local MinIO service above (non-production
# only; production refuses to boot without them). For Cloudflare R2, set the
# account endpoint and an API token's credentials; S3_REGION stays "auto".
#S3_ENDPOINT=http://localhost:9000
#S3_ACCESS_KEY_ID=aero
#S3_SECRET_ACCESS_KEY=aero_dev_password
#S3_REGION=auto

# --- Web ---
# Where the Vite dev server proxies /api requests for non-Docker local runs;
# inside Docker Compose this is set to http://api:3000 automatically.
API_PROXY_TARGET=http://localhost:3000
