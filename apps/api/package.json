{
  "name": "@aero/api",
  "version": "0.1.0",
  "private": true,
  "description": "Express API, background jobs, and (future) PDF file-origin proxy",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "TEST_DATABASE_URL=\"${TEST_DATABASE_URL:-postgresql://aero:aero_dev_password@localhost:5432/aero_test}\" vitest run src/integration",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@aero/shared": "0.1.0",
    "@aws-sdk/client-s3": "^3.1088.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "node-cron": "^4.6.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/supertest": "^7.2.1",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}
